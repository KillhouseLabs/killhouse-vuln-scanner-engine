    "feedback_loops": {
      "Observe-Orient-Decide-Act (OODA)": {
        "origin": "Military decision-making (John Boyd)",
        "phases": {
          "Observe": "Collect vulnerability scan results, system state, attack outcomes",
          "Orient": "Analyze results, identify patterns, contextualize findings",
          "Decide": "Select next attack vector, adjust policy parameters",
          "Act": "Execute next test, update configurations"
        },
        "advantages": [
          "Fast iteration cycles",
          "Adaptive to changing conditions",
          "Proven in adversarial contexts"
        ],
        "security_application": "Adaptive penetration testing with real-time strategy adjustment",
        "implementation_complexity": "Medium"
      },
      "Plan-Do-Check-Act (PDCA)": {
        "origin": "Quality management (Deming Cycle)",
        "phases": {
          "Plan": "Define vulnerability test scope, hypotheses, success criteria",
          "Do": "Execute vulnerability scans, proof-of-concepts",
          "Check": "Validate results, measure coverage, identify gaps",
          "Act": "Refine policies, adjust parameters, iterate"
        },
        "advantages": [
          "Systematic improvement",
          "Clear documentation trail",
          "Quality-focused"
        ],
        "security_application": "Methodical vulnerability assessment with continuous improvement",
        "implementation_complexity": "Low"
